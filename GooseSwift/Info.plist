<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.tymure.oops.health</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>oops</string>
				<string>gooseswift</string>
			</array>
		</dict>
	</array>
	<key>CFBundleDisplayName</key>
	<string>OOPS</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>LSSupportsOpeningDocumentsInPlace</key>
	<true/>
	<key>NSBluetoothAlwaysUsageDescription</key>
	<string>OOPS uses Bluetooth to connect to your owned WHOOP strap and read a local hello response.</string>
	<key>NSBluetoothPeripheralUsageDescription</key>
	<string>OOPS uses Bluetooth to connect to your owned WHOOP strap and read a local hello response.</string>
	<key>NSHealthShareUsageDescription</key>
	<string>OOPS reads Apple Health body mass only to prefill your local profile weight.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>OOPS uses background location to keep tracking outdoor workout routes, pace, and distance when you minimize the app.</string>
	<key>NSLocationAlwaysUsageDescription</key>
	<string>OOPS uses background location to keep tracking outdoor workout routes, pace, and distance when you minimize the app.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>OOPS uses location to record outdoor workout routes, pace, distance, and elevation.</string>
	<key>NSSupportsLiveActivities</key>
	<true/>
	<key>NSSupportsLiveActivitiesFrequentUpdates</key>
	<true/>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>UIFileSharingEnabled</key>
	<true/>
	<key>UILaunchScreen</key>
	<dict/>
	<key>UIBackgroundModes</key>
	<array>
		<string>bluetooth-central</string>
		<string>location</string>
	</array>
</dict>
</plist>
